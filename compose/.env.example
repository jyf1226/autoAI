TZ=Asia/Shanghai

# Core service ports
OPENWEBUI_PORT=3000
QDRANT_PORT=6333
N8N_PORT=5678

# Postgres
POSTGRES_DB=aiworkflow
POSTGRES_USER=aiuser
POSTGRES_PASSWORD=change_me_postgres_password

# n8n auth
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# Open WebUI
WEBUI_AUTH=True
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Optional alias used by github-watch if OLLAMA_BASE_URL is empty
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
OLLAMA_TIMEOUT_SECONDS=120

# github-watch
GITHUB_TOKEN=ghp_xxx_replace_me
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WATCH_POLL_INTERVAL_SECONDS=3600
GITHUB_WATCH_REQUEST_SLEEP_SECONDS=1
GITHUB_WATCH_HTTP_TIMEOUT_SECONDS=30
GITHUB_WATCH_MAX_RETRIES=3
GITHUB_WATCH_LOG_LEVEL=INFO
